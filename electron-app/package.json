{
  "name": "rift-radar-electron",
  "version": "0.1.0",
  "description": "League of Legends champion draft analysis tool with live client integration",
  "main": "main.js",
  "homepage": "https://github.com/etrobert/rift-radar",
  "author": {
    "name": "Rift Radar Team"
  },
  "scripts": {
    "start": "electron .",
    "dev": "NODE_ENV=development electron .",
    "build": "npm run build:react && npm run copy:dist",
    "build:react": "cd ../frontend && npm run build",
    "copy:dist": "cp -r ../frontend/dist .",
    "clean": "rm -rf dist",
    "dist": "npm run build && electron-builder",
    "dist:win": "npm run build && electron-builder --win",
    "dist:mac": "npm run build && electron-builder --mac",
    "dist:linux": "npm run build && electron-builder --linux"
  },
  "build": {
    "appId": "com.riftradar.app",
    "productName": "Rift Radar",
    "directories": {
      "output": "releases"
    },
    "publish": {
      "provider": "github",
      "owner": "etrobert",
      "repo": "rift-radar"
    },
    "files": [
      "main.js",
      "preload.js",
      "dist/**/*",
      "node_modules/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        },
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ]
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": ["x64", "arm64"]
        }
      ]
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": ["x64"]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  },
  "keywords": [
    "league-of-legends",
    "champion-select",
    "draft-analysis",
    "electron"
  ],
  "license": "ISC",
  "devDependencies": {
    "electron": "^36.4.0",
    "electron-builder": "^26.0.12"
  },
  "dependencies": {
    "league-connect": "^6.0.0-rc13"
  }
}
